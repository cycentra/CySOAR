# CySOAR Support System - SMTP Configuration
# Copy this file to .env and update with your SMTP server details

# SMTP Server Configuration
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=noreply@cycentra.com
SMTP_PASS=your-password-here

# For Gmail:
# 1. Enable 2-factor authentication
# 2. Create an "App Password": https://myaccount.google.com/apppasswords
# 3. Use the generated 16-character password as SMTP_PASS

# For Office 365:
# SMTP_HOST=smtp.office365.com
# SMTP_PORT=587
# SMTP_USER=your-email@company.com
# SMTP_PASS=your-password

# For Amazon SES:
# SMTP_HOST=email-smtp.us-east-1.amazonaws.com
# SMTP_PORT=587
# SMTP_USER=your-ses-smtp-username
# SMTP_PASS=your-ses-smtp-password

# For SendGrid:
# SMTP_HOST=smtp.sendgrid.net
# SMTP_PORT=587
# SMTP_USER=apikey
# SMTP_PASS=your-sendgrid-api-key

# Support Email Destination
# (Email address where support requests will be sent)
SUPPORT_EMAIL=support@cycentra.com
